datasource db{
  provider = "sqlite"
}
generator client {
  provider = "prisma-client-js"
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  tasks     Task[]  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("TODO")
  priority    Int
  

  user        User     @relation(fields: [userId], references: [id])
  userId      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}